---
- name: "Compfuzor: synthesize get_urls artifacts"
  set_fact:
    BINS: "{{ [BINS | default([]), _get_urls_contrib.BINS | default([])] | merge_list('bins_generated') }}"
  when: lookup('subsys', id='get_urls', get='active', default=false) | bool
  vars:
    _get_urls_contrib: "{{ lookup('subsys', id='get_urls', get='contrib', default={}) }}"
