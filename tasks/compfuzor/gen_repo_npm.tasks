---
- name: "Compfuzor: synthesize repo_npm subsystem artifacts"
  set_fact:
    BINS: "{{ [BINS | default([]), lookup('subsys', id='repo_npm', get='contrib.BINS', default=[])] | merge_with_strategy('bins_generated', into='BINS') }}"
    ETC_FILES: "{{ lookup('subsys', id='repo_npm', get='contrib.ETC_FILES', default=[]) | concat2(ETC_FILES) }}"
  when: lookup('subsys', id='repo_npm', get='active', default=false) | bool
