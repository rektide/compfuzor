---
- name: "Compfuzor: synthesize repo_npm subsystem artifacts"
  set_fact:
    BINS: "{{ BINS | merge_list_subsys('repo_npm') }}"
    ETC_FILES: "{{ ETC_FILES | merge_list_subsys('repo_npm', path='contrib.ETC_FILES', strategy='append') }}"
  when: lookup('subsys', id='repo_npm', get='active', default=false) | bool
