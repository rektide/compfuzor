---
- name: "Compfuzor: synthesize cmake subsystem artifacts"
  set_fact:
    BINS: "{{ lookup('merge_subsys', id='cmake', contrib='BINS') }}"
    PKGS: "{{ lookup('merge_subsys', id='cmake', contrib='PKGS', strategy='append') }}"
    ENV: "{{ lookup('merge_subsys', id='cmake', contrib='ENV') }}"
  when: lookup('subsys', id='cmake', get='active', default=false) | bool
