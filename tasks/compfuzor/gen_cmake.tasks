---
- name: "Compfuzor: synthesize cmake subsystem artifacts"
  set_fact:
    BINS: "{{ BINS | merge_list_subsys('cmake') }}"
    PKGS: "{{ PKGS | merge_list_subsys('cmake', path='contrib.PKGS', strategy='append') }}"
    ENV: "{{ ENV | merge_dict_subsys('cmake') }}"
  when: lookup('subsys', id='cmake', get='active', default=false) | bool
