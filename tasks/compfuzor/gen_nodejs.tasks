---
- name: "Compfuzor: synthesize nodejs subsystem artifacts"
  set_fact:
    BINS: "{{ [BINS | default([]), lookup('subsys', id='nodejs', get='contrib.BINS', default=[])] | merge_with_strategy('bins_generated', into='BINS') }}"
    ENV: "{{ lookup('subsys', id='nodejs', get='contrib.ENV') | combine(existingEnv) }}"
  when: lookup('subsys', id='nodejs', get='active', default=false) | bool
  vars:
    existingEnv: "{{ ENV if ENV is mapping else {} }}"
