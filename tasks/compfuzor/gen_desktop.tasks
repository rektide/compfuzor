---
- name: "Compfuzor: synthesize desktop subsystem artifacts"
  set_fact:
    BINS: "{{ lookup('merge_subsys', id='desktop', contrib='BINS') }}"
    PKGS: "{{ lookup('merge_subsys', id='desktop', contrib='PKGS', strategy='append') }}"
  when: lookup('subsys', id='desktop', get='active', default=false) | bool
