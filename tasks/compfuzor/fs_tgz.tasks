- name: "Compfuzor: fetch tgz file"
  get_url:
    url: "{{TGZ}}"
    dest: "{{_dest}}"
    owner: "{{OWNER|default(omit)}}"
    group: "{{GROUP|default(omit)}}"
  become: "{{ COMFUZOR_SHOULD_BECOME|default(BECOME|default(_dest|should_become(OWNER|default(), _cf_user_id, GROUP|default(), _cf_user_gid)))|bool }}"
  vars:
    _dest: "{{SRCS_DIR}}/{{TGZ|basename}}"
- name: prep TGZ.url file
  set_fact:
    content: "{{TGZ}}"
- name: record TGZ.url file"
  template:
    src: "files/content"
    dest: "{{_dest}}"
    owner: "{{OWNER|default(omit)}}"
    group: "{{GROUP|default(omit)}}"
  become: "{{ COMFUZOR_SHOULD_BECOME|default(BECOME|default(_dest|should_become(OWNER|default(), _cf_user_id, GROUP|default(), _cf_user_gid)))|bool }}"
  vars:
    _dest: "{{SRCS_DIR}}/{{TGZ|basename}}.url"
- name: extract tgz
  shell: "tar -xaf {{_tar}} --strip-components={{TGZ_STRIP_COMPONENTS|default(1)}}"
  #unarchive: src="{{SRCS_DIR}}/{{TGZ|basename}}" dest="{{DIR}}" copy="no"
  args:
    chdir: "{{DIR}}"
  become: "{{ COMFUZOR_SHOULD_BECOME|default(BECOME|default(_tar|should_become(OWNER|default(), _cf_user_id, GROUP|default(), _cf_user_gid)))|bool }}"
  vars:
    _tar: "{{SRCS_DIR}}/{{TGZ|basename}}"
