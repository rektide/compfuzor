---
- name: "Compfuzor: synthesize kernel subsystem artifacts"
  set_fact:
    ETC_FILES: "{{ lookup('merge_subsys', id='kernel_all', contrib='ETC_FILES') }}"
    BINS: "{{ lookup('merge_subsys', id='kernel_all', contrib='BINS') }}"
    ENV: "{{ lookup('merge_subsys', id='kernel_all', contrib='ENV') }}"
    ENV_LIST: "{{ lookup('merge_subsys', id='kernel_all', contrib='ENV_LIST') }}"
    PKGS: "{{ lookup('merge_subsys', id='kernel_all', contrib='PKGS') }}"
  when: lookup('subsys', id='kernel_all', get='active', default=false) | bool
