    _bin_item:
      name: install-socket-user.sh
      generatedAt: end
      generated: |
        UNIT_NAME="{{ _unit_name }}"
        UNIT_TYPE=socket
        UNIT_SUFFIX=user
        USERMODE=true
        source "$(dirname "$0")/../etc/install-unit.sh"

- name: 'Generate systemd user mount install script'
  set_fact:
    BINS: "{{ BINS|default([]) + [_bin_item] }}"
  when: _systemd_has_mount and SYSTEMD_USER_MOUNT_INSTALL|default(false) and not SYSTEMD_INSTALL_BYPASS|default(False)
  vars:
    _unit_name: "{{ SYSTEMD_MOUNT if SYSTEMD_MOUNT|default(false) and SYSTEMD_MOUNT not in [True, 'True'] else NAME }}"
    _bin_item:
      name: install-mount-user.sh
