        source "$(dirname "$0")/../etc/install-unit.sh"

- name: 'Generate systemd user dnssd install script'
  set_fact:
    BINS: "{{ BINS|default([]) + [_bin_item] }}"
  when: _systemd_has_dnssd and SYSTEMD_USER_DNSSD_INSTALL|default(false) and not SYSTEMD_INSTALL_BYPASS|default(False)
  vars:
