---
- name: "Compfuzor: synthesize tool_versions subsystem artifacts"
  set_fact:
    ETC_FILES: "{{ lookup('subsys', id='tool_versions', get='contrib.artifacts.ETC_FILES', default=[]) | concat2(ETC_FILES) }}"
    LINKS: "{{ lookup('subsys', id='tool_versions', get='contrib.artifacts.LINKS', default=[]) | concat2(LINKS) }}"
  when: lookup('subsys', id='tool_versions', get='active', default=false) | bool
