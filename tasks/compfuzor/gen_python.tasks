---
- name: "Compfuzor: synthesize python subsystem artifacts"
  set_fact:
    BINS: "{{ lookup('merge_subsys', id='python', contrib='BINS') }}"
    ENV: "{{ lookup('merge_subsys', id='python', contrib='ENV') }}"
    ETC_FILES: "{{ lookup('merge_subsys', id='python', contrib='ETC_FILES') }}"
  when: lookup('subsys', id='python', get='active', default=false) | bool
