- name: 'Set config client directories and bins'
  set_fact:
    ETC_DIRS: "{{ config_dirs | concat(ETC_DIRS|default([])) }}"
    BINS: "{{ [config_bin, disable_bin, enable_bin] | mergeKeyed(BINS|default([])) }}"
    ENV_LIST: "{{ ENV_LIST|default([]) + config_env_list }}"
  vars:
    config_dirs:
      - "{{ CONFIG_KEY }}"
      - "{{ CONFIG_KEY }}-disabled"
    config_bin:
      name: config.sh
      src: "../config-{{ CONFIG_MERGE | default('yaml-list') }}.sh"
      basedir: False
    disable_bin:
      name: disable.sh
      src: ../config-disable.sh
      basedir: False
    enable_bin:
      name: enable.sh
      src: ../config-enable.sh
      basedir: False
    config_env_list:
      - CONFIG_KEY
      - CONFIG_EXT
      - CONFIG_OUTPUT
  when: CONFIG_KEY is defined
