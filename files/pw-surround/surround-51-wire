#!/bin/bash
# surround-51-wire — Route surround_51_output ports to hardware devices via pw-link.
#
# After the filter-chain creates the 6-channel virtual sink, PipeWire auto-connects
# the playback output to hardware devices. This script disconnects those auto-links
# and creates explicit per-channel routing to the correct physical speakers.
#
# Device node names are resolved at runtime: env var > Jinja-rendered playbook default.

# Hardware device PipeWire node names
# Priority: runtime env var > Jinja-rendered playbook default
DEV_L="${PW_SURROUND_DEVICE_L:-{{PW_SURROUND_DEVICE_L}}}"
DEV_R="${PW_SURROUND_DEVICE_R:-{{PW_SURROUND_DEVICE_R}}}"
DEV_SUB="${PW_SURROUND_DEVICE_SUB:-{{PW_SURROUND_DEVICE_SUB}}}"

# Wait for the surround_51_output node to appear after pipewire restart
for i in $(seq 1 30); do
  if pw-link -o 2>/dev/null | grep -q "surround_51_output:"; then
    break
  fi
  sleep 0.5
done

if ! pw-link -o 2>/dev/null | grep -q "surround_51_output:"; then
  echo "Error: surround_51_output node not found after waiting" >&2
  exit 1
fi

SRC="surround_51_output"

# Disconnect all auto-linked connections from our output to any hardware device.
# Without this, PipeWire sends FL/FR to every device by default.
for dev in "$DEV_L" "$DEV_R" "$DEV_SUB"; do
  for ch in FL FR FC LFE RL RR; do
    pw-link -d "${SRC}:output_${ch}" "${dev}:playback_FL" 2>/dev/null || true
    pw-link -d "${SRC}:output_${ch}" "${dev}:playback_FR" 2>/dev/null || true
  done
done

# Physical speaker mapping:
#
#   Mpow HC5 (Kali Audio monitors via LP-UNF USB adapter)
#     Left channel  = Rear Left speaker
#     Right channel = Front Left speaker (receives mixed FL + center)
#
#   FiiO E10 (WEILIANG 24BIT USB DAC)
#     Left channel  = Front Right speaker (receives mixed FR + center)
#     Right channel = Rear Right speaker
#
#   SB X-Fi Surround 5.1 Pro
#     Both channels = Subwoofer (the device's own crossover handles filtering)

# DEV_L: left-front + left-rear (L channel = rear left, R channel = front left)
pw-link "${SRC}:output_FL" "${DEV_L}:playback_FR"
pw-link "${SRC}:output_RL" "${DEV_L}:playback_FL"

# DEV_R: right-front + right-rear (L channel = front right, R channel = rear right)
pw-link "${SRC}:output_FR" "${DEV_R}:playback_FL"
pw-link "${SRC}:output_RR" "${DEV_R}:playback_FR"

# DEV_SUB: subwoofer on both channels (mono)
pw-link "${SRC}:output_LFE" "${DEV_SUB}:playback_FL"
pw-link "${SRC}:output_LFE" "${DEV_SUB}:playback_FR"

echo "Surround 5.1 wiring complete."
echo "  FL+center -> ${DEV_L}:R (front left speaker)"
echo "  FR+center -> ${DEV_R}:L (front right speaker)"
echo "  RL        -> ${DEV_L}:L (rear left speaker)"
echo "  RR        -> ${DEV_R}:R (rear right speaker)"
echo "  sub mix   -> ${DEV_SUB}   (subwoofer)"
